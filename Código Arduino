void drawLabelValue(int x, int y, String label, String value) {
  fill(70, 210, 120);
  textSize(13);
  text(label, x, y);

  fill(100, 255, 180);
  textSize(16);
  text(value, x, y + 14);
}

void drawBpmTrend(int x, int y, int w, int h) {
  noFill();

  stroke(0, 120, 50);
  rect(x, y, w, h);

  if (bpmTrend.size() < 2) {
    return;
  }

  stroke(100, 255, 180);
  strokeWeight(1.8);

  beginShape();

  for (int i = 0; i < bpmTrend.size(); i++) {
    float px = map(i, 0, bpmTrend.size() - 1, x + 2, x + w - 2);
    float py = map(bpmTrend.get(i), 40, 140, y + h - 3, y + 3);

    py = constrain(py, y + 3, y + h - 3);

    vertex(px, py);
  }

  endShape();
}

int getLastRR() {
  if (rrList.size() == 0) {
    return 0;
  }

  return rrList.get(rrList.size() - 1);
}

void serialEvent(Serial p) {
  String data = p.readStringUntil('\n');

  if (data != null) {
    serialQueue.add(data);

    while (serialQueue.size() > 3000) {
      serialQueue.removeFirst();
    }
  }
}

void keyPressed() {
  if (key == '+' || key == '=') {
    manualGain += 0.10;
    manualGain = constrain(manualGain, 0.4, 3.0);
  }

  if (key == '-' || key == '_') {
    manualGain -= 0.10;
    manualGain = constrain(manualGain, 0.4, 3.0);
  }

  if (keyCode == UP) {
    yOffset -= 10;
  }

  if (keyCode == DOWN) {
    yOffset += 10;
  }

  if (key == '1') {
    experimentState = "REPOSO";
  }

  if (key == '2') {
    experimentState = "ATENCION";
  }

  if (key == '3') {
    experimentState = "ESTRES_COGNITIVO";
  }

  if (key == '4') {
    experimentState = "RECUPERACION";
  }

  if (key == 'r' || key == 'R') {
    resetAnalysis();
  }

  if (key == 's' || key == 'S') {
    saveFrame("ecg_tdah_####.png");
  }

  if (key == 'g' || key == 'G') {
    if (writer != null) {
      writer.flush();
    }

    println("CSV guardado");
  }
}

void resetAnalysis() {
  rrList.clear();
  bpmTrend.clear();

  bpm = 0;
  bpmSmooth = 0;
  rrMean = 0;
  sdnn = 0;
  rmssd = 0;
  pnn50 = 0;
  sqi = 0;

  spki = 0.03;
  npki = 0.005;
  threshold = 0.02;

  lastRSample = -999999;

  goodBeats = 0;
  rejectedBeats = 0;

  signalStatus = "CALIBRANDO";
  tdahProfile = "Esperando señal estable";
}

void exit() {
  if (writer != null) {
    writer.flush();
    writer.close();
  }

  super.exit();
}

class Biquad {
  float b0, b1, b2, a1, a2;
  float x1 = 0;
  float x2 = 0;
  float y1 = 0;
  float y2 = 0;

  void setNotch(float f0, float fs, float Q) {
    float w0 = TWO_PI * f0 / fs;
    float cosw0 = cos(w0);
    float alpha = sin(w0) / (2.0 * Q);

    float bb0 = 1.0;
    float bb1 = -2.0 * cosw0;
    float bb2 = 1.0;

    float aa0 = 1.0 + alpha;
    float aa1 = -2.0 * cosw0;
    float aa2 = 1.0 - alpha;

    b0 = bb0 / aa0;
    b1 = bb1 / aa0;
    b2 = bb2 / aa0;
    a1 = aa1 / aa0;
    a2 = aa2 / aa0;
  }

  void setLowpass(float f0, float fs, float Q) {
    float w0 = TWO_PI * f0 / fs;
    float cosw0 = cos(w0);
    float sinw0 = sin(w0);
    float alpha = sinw0 / (2.0 * Q);

    float bb0 = (1.0 - cosw0) / 2.0;
    float bb1 = 1.0 - cosw0;
    float bb2 = (1.0 - cosw0) / 2.0;

    float aa0 = 1.0 + alpha;
    float aa1 = -2.0 * cosw0;
    float aa2 = 1.0 - alpha;

    b0 = bb0 / aa0;
    b1 = bb1 / aa0;
    b2 = bb2 / aa0;
    a1 = aa1 / aa0;
    a2 = aa2 / aa0;
  }

  void setHighpass(float f0, float fs, float Q) {
    float w0 = TWO_PI * f0 / fs;
    float cosw0 = cos(w0);
    float sinw0 = sin(w0);
    float alpha = sinw0 / (2.0 * Q);

    float bb0 = (1.0 + cosw0) / 2.0;
    float bb1 = -(1.0 + cosw0);
    float bb2 = (1.0 + cosw0) / 2.0;

    float aa0 = 1.0 + alpha;
    float aa1 = -2.0 * cosw0;
    float aa2 = 1.0 - alpha;

    b0 = bb0 / aa0;
    b1 = bb1 / aa0;
    b2 = bb2 / aa0;
    a1 = aa1 / aa0;
    a2 = aa2 / aa0;
  }

  float process(float x) {
    float y = b0 * x + b1 * x1 + b2 * x2 - a1 * y1 - a2 * y2;

    x2 = x1;
    x1 = x;

    y2 = y1;
    y1 = y;

    return y;
  }
}
